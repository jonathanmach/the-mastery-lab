# HAPI FHIR (local Docker)
FHIR_BASE_URL=http://localhost:8081/fhir

# OpenSearch (local Docker)
OPENSEARCH_ENDPOINT=http://localhost:9200
OPENSEARCH_INDEX=patients

# Import tracking DB (SQLite)
DATABASE_URL=sqlite:///./import_tracking.db

# Synthea bundles directory (local path)
SYNTHEA_BUNDLES_DIR=./data/synthea_bundles

LOG_LEVEL=INFO
